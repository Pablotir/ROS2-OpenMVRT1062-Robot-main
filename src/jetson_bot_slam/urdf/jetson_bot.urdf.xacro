<?xml version="1.0"?>
<!--
  jetson_bot.urdf.xacro
  =====================
  Robot description for the mecanum-drive Jetson bot.

  Physical dimensions (18.5 in wide x 13.5 in long, 13 in tall without LiDAR)
  Base length (x) = 0.343 m  (13.5 in)
  Base width  (y) = 0.470 m  (18.5 in)
  Base height (z) = 0.080 m  (approx chassis plate height)
  Wheel radius    = 0.0508 m (2 in)
  Wheel thickness = 0.038 m  (1.5 in)
  Half wheelbase  = 0.127 m  (5.0 in, Lx)
  Half track      = 0.217 m  (8.55 in, Ly)
  Total height    = 0.330 m  (13 in, without LiDAR)

  Sensor placement (all centred widthwise, heights measured from ground):
  LiDAR:      LDROBOT STL-27L, DEAD CENTRE of robot, scan plane at 14⅝"–15"
  Camera:     USB camera at front-centre, sensor at 7⅝" height
  Ultrasonic: HC-SR04 rear-centre, facing backward, at 6½" height
-->
<robot name="jetson_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Colours -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.5 0.9 1"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1"/>
  </material>
  <material name="green">
    <color rgba="0.1 0.8 0.2 1"/>
  </material>

  <!-- Properties -->
  <xacro:property name="base_length"    value="0.343"/>
  <xacro:property name="base_width"     value="0.470"/>
  <xacro:property name="base_height"    value="0.080"/>
  <xacro:property name="wheel_radius"   value="0.0508"/>
  <xacro:property name="wheel_width"    value="0.038"/>
  <xacro:property name="half_lx"        value="0.127"/>   <!-- half wheelbase (Lx) -->
  <xacro:property name="half_ly"        value="0.217"/>   <!-- half track (Ly) -->
  <xacro:property name="lidar_height"   value="0.010"/>   <!-- spinning cylinder ~3/8 in -->

  <!-- Ground-to-base_link offset: base_link is at centre of chassis plate,
       chassis bottom sits at wheel-axle height (wheel_radius above ground) -->
  <xacro:property name="base_z"  value="${wheel_radius + base_height/2}"/>
  <!--  = 0.0508 + 0.040 = 0.0908 m above ground  -->

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_link">
      <visual>
        <geometry><cylinder length="${wheel_width}" radius="${wheel_radius}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder length="${wheel_width}" radius="${wheel_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0003" ixy="0" ixz="0"
                              iyy="0.0003" iyz="0"
                                          izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <!-- Wheel axle is at the bottom of the chassis: z = -(base_height/2) -->
      <origin xyz="${x} ${y} ${-base_height/2}"
              rpy="${pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- ===================================================================== -->
  <!-- base_footprint - ground contact frame used by Nav2                    -->
  <!-- ===================================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <!-- base_link centre = wheel_radius + base_height/2 above ground -->
    <origin xyz="0 0 ${base_z}"/>
  </joint>

  <!-- ===================================================================== -->
  <!-- base_link - robot body                                                 -->
  <!-- ===================================================================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <!-- Solid box inertia approximation -->
      <inertia
        ixx="${(3.0/12.0)*(base_width*base_width + base_height*base_height)}"
        ixy="0" ixz="0"
        iyy="${(3.0/12.0)*(base_length*base_length + base_height*base_height)}"
        iyz="0"
        izz="${(3.0/12.0)*(base_length*base_length + base_width*base_width)}"/>
    </inertial>
  </link>

  <!-- ===================================================================== -->
  <!-- Wheels: FL, FR, BL, BR                                                -->
  <!-- ===================================================================== -->
  <xacro:wheel name="wheel_FL" x=" ${half_lx}" y=" ${half_ly}"/>
  <xacro:wheel name="wheel_FR" x=" ${half_lx}" y="${-half_ly}"/>
  <xacro:wheel name="wheel_BL" x="${-half_lx}" y=" ${half_ly}"/>
  <xacro:wheel name="wheel_BR" x="${-half_lx}" y="${-half_ly}"/>

  <!-- ===================================================================== -->
  <!-- Camera link (USB camera, front-centre, sensor at 7⅝" = 0.1937 m)    -->
  <!-- ===================================================================== -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <!-- Front-centre: x = base_length/2, y = 0
         Height: 7.625" = 0.1937 m above ground → z relative to base_link -->
    <origin xyz="${base_length/2} 0 ${0.1937 - base_z}"
            rpy="0 0 0"/>
  </joint>

  <!-- Optical frame: Z forward, X right, Y down (standard for OpenCV / ROS) -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ===================================================================== -->
  <!-- LiDAR — LDROBOT STL-27L, DEAD CENTRE of robot                        -->
  <!-- Spinning bit: 14⅝" (0.3716 m) to 15" (0.381 m) above ground         -->
  <!-- ===================================================================== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder length="${lidar_height}" radius="0.035"/></geometry>
      <material name="green"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <!-- Dead centre: x=0, y=0
         LiDAR mid-height = (14.625+15)/2 = 14.8125" = 0.3763 m above ground -->
    <origin xyz="0 0 ${0.3763 - base_z}"
            rpy="0 0 0"/>
  </joint>

  <!-- laser_frame: the actual scan plane (top of spinning bit, required by ldlidar_stl_ros2) -->
  <link name="laser_frame"/>
  <joint name="laser_frame_joint" type="fixed">
    <parent link="lidar_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0 0 ${lidar_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================== -->
  <!-- Ultrasonic sensor (HC-SR04, REAR-centre, facing backward)             -->
  <!-- Height: 6½" = 0.1651 m above ground                                   -->
  <!-- ===================================================================== -->
  <link name="ultrasonic_link">
    <visual>
      <geometry><box size="0.045 0.020 0.015"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="ultrasonic_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="ultrasonic_link"/>
    <!-- Rear-centre facing backward: x = -(base_length/2 - 0.01), y = 0
         Height: 6.5" = 0.1651 m above ground → z relative to base_link -->
    <origin xyz="${-(base_length/2 - 0.01)} 0 ${0.1651 - base_z}"
            rpy="0 0 ${pi}"/>
  </joint>

</robot>
